{
  "welcome": {
    "id": "welcome",
    "type": "message",
    "content": "Hi there! 👋 I'm your AI physio assistant. I'm here to help you on your recovery journey!",
    "delay": 1000,
    "nextQuestion": "get_started"
  },
  "get_started": {
    "id": "get_started",
    "type": "message",
    "content": "Let's get to know you better so I can personalize your experience. This will take just a minute! 😊",
    "delay": 800,
    "nextQuestion": "personal_info_intro"
  },
  "personal_info_intro": {
    "id": "personal_info_intro",
    "type": "message",
    "content": "First, let's start with some basic information about you...",
    "delay": 600,
    "nextQuestion": "name"
  },
  "name": {
    "id": "name",
    "type": "input",
    "content": "What's your name?",
    "inputType": "text",
    "placeholder": "Enter your name",
    "validation": {
      "required": true,
      "minLength": 2,
      "maxLength": 50
    },
    "nextQuestion": "name_response"
  },
  "name_response": {
    "id": "name_response",
    "type": "message",
    "content": "Nice to meet you, {name}! 😊",
    "delay": 600,
    "nextQuestion": "dob"
  },
  "dob": {
    "id": "dob",
    "type": "input",
    "content": "What's your date of birth? (DD/MM/YYYY)",
    "inputType": "text",
    "placeholder": "DD/MM/YYYY",
    "validation": {
      "required": true,
      "pattern": "date"
    },
    "nextQuestion": "gender"
  },
  "gender": {
    "id": "gender",
    "type": "choice",
    "content": "How do you identify?",
    "options": [
      {
        "id": "male",
        "label": "Male",
        "value": "male"
      },
      {
        "id": "female",
        "label": "Female",
        "value": "female"
      },
      {
        "id": "other",
        "label": "Other",
        "value": "other"
      },
      {
        "id": "prefer_not_to_say",
        "label": "Prefer not to say",
        "value": "prefer_not_to_say"
      }
    ],
    "nextQuestion": "profession"
  },
  "profession": {
    "id": "profession",
    "type": "input",
    "content": "What's your profession?",
    "inputType": "text",
    "placeholder": "e.g., Software Engineer, Teacher",
    "validation": {
      "required": true,
      "minLength": 2,
      "maxLength": 50
    },
    "nextQuestion": "profession_response"
  },
  "profession_response": {
    "id": "profession_response",
    "type": "message",
    "content": "Great! Now let's understand your work routine...",
    "delay": 600,
    "nextQuestion": "work_mode"
  },
  "work_mode": {
    "id": "work_mode",
    "type": "choice",
    "content": "What's your primary work mode?",
    "options": [
      {
        "id": "wfh",
        "label": "🏠 Work From Home",
        "value": "wfh"
      },
      {
        "id": "office",
        "label": "🏢 Office",
        "value": "office"
      },
      {
        "id": "hybrid",
        "label": "🔄 Hybrid",
        "value": "hybrid"
      }
    ],
    "nextQuestion": "sitting_hours"
  },
  "sitting_hours": {
    "id": "sitting_hours",
    "type": "choice",
    "content": "On average, how many hours do you sit per day?",
    "options": [
      {
        "id": "less_than_2",
        "label": "Less than 2 hours",
        "value": "<2"
      },
      {
        "id": "2_to_4",
        "label": "2-4 hours",
        "value": "2-4"
      },
      {
        "id": "4_to_6",
        "label": "4-6 hours",
        "value": "4-6"
      },
      {
        "id": "6_to_8",
        "label": "6-8 hours",
        "value": "6-8"
      },
      {
        "id": "more_than_8",
        "label": "More than 8 hours",
        "value": ">8"
      }
    ],
    "nextQuestion": "discomfort_intro"
  },
  "discomfort_intro": {
    "id": "discomfort_intro",
    "type": "message",
    "content": "Now, let's talk about any discomfort you might be experiencing...",
    "delay": 600,
    "nextQuestion": "areas_of_discomfort"
  },
  "areas_of_discomfort": {
    "id": "areas_of_discomfort",
    "type": "multi-choice",
    "content": "Which areas do you experience discomfort? (Select all that apply)",
    "options": [
      {
        "id": "neck",
        "label": "🦒 Neck",
        "value": "neck"
      },
      {
        "id": "shoulders",
        "label": "💪 Shoulders",
        "value": "shoulders"
      },
      {
        "id": "upper_back",
        "label": "⬆️ Upper Back",
        "value": "upper_back"
      },
      {
        "id": "lower_back",
        "label": "⬇️ Lower Back",
        "value": "lower_back"
      },
      {
        "id": "wrists",
        "label": "✋ Wrists/Hands",
        "value": "wrists"
      },
      {
        "id": "hips",
        "label": "🦴 Hips",
        "value": "hips"
      },
      {
        "id": "knees",
        "label": "🦵 Knees",
        "value": "knees"
      },
      {
        "id": "none",
        "label": "✅ No discomfort currently",
        "value": "none",
        "exclusive": true
      }
    ],
    "minSelections": 1,
    "nextQuestion": "frequency"
  },
  "frequency": {
    "id": "frequency",
    "type": "choice",
    "content": "How often do you experience this discomfort?",
    "options": [
      {
        "id": "constantly",
        "label": "Constantly (all the time)",
        "value": "constantly"
      },
      {
        "id": "daily",
        "label": "Daily",
        "value": "daily"
      },
      {
        "id": "few_times_week",
        "label": "Few times a week",
        "value": "few_times_week"
      },
      {
        "id": "weekly",
        "label": "Once a week",
        "value": "weekly"
      },
      {
        "id": "occasionally",
        "label": "Occasionally",
        "value": "occasionally"
      }
    ],
    "conditionalDisplay": {
      "field": "areas_of_discomfort",
      "condition": "not_contains",
      "value": "none"
    },
    "nextQuestion": "time_of_discomfort"
  },
  "time_of_discomfort": {
    "id": "time_of_discomfort",
    "type": "multi-choice",
    "content": "When do you typically experience discomfort? (Select all that apply)",
    "options": [
      {
        "id": "morning",
        "label": "🌅 Morning (after waking up)",
        "value": "morning"
      },
      {
        "id": "during_work",
        "label": "💼 During work hours",
        "value": "during_work"
      },
      {
        "id": "afternoon",
        "label": "☀️ Afternoon",
        "value": "afternoon"
      },
      {
        "id": "evening",
        "label": "🌆 Evening",
        "value": "evening"
      },
      {
        "id": "night",
        "label": "🌙 Night (before bed)",
        "value": "night"
      },
      {
        "id": "after_activity",
        "label": "🏃 After physical activity",
        "value": "after_activity"
      }
    ],
    "minSelections": 1,
    "conditionalDisplay": {
      "field": "areas_of_discomfort",
      "condition": "not_contains",
      "value": "none"
    },
    "nextQuestion": "completion_message"
  },
  "completion_message": {
    "id": "completion_message",
    "type": "message",
    "content": "Perfect! {name}, I now have a good understanding of your needs. 🎉",
    "delay": 800,
    "nextQuestion": "final_cta"
  },
  "final_cta": {
    "id": "final_cta",
    "type": "message",
    "content": "I'm ready to create a personalized plan just for you! Let's start your wellness journey together! 💪",
    "delay": 600,
    "nextQuestion": "journey_start"
  },
  "journey_start": {
    "id": "journey_start",
    "type": "cta",
    "content": "Ready to begin?",
    "buttonText": "Start My Journey"
  }
}
